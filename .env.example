# ── Vertex AI / Gemini ────────────────────────────────────────────────────────
# GCP project where the Vertex AI API is enabled (required).
VERTEX_AI_PROJECT=your-gcp-project-id

# Region where the model runs. us-central1 supports all Gemini models.
VERTEX_AI_LOCATION=us-central1

# Gemini model served through Vertex AI.
# Recommended: gemini-2.5-flash (fast + cheap) or gemini-2.5-pro (more capable).
GEMINI_MODEL=gemini-2.5-flash

# ── Google Authentication ─────────────────────────────────────────────────────
# The backend resolves BigQuery credentials in this priority order:
#
#   1. Per-request Bearer token sent by the browser (UI login) — automatic, no config.
#
#   2. GOOGLE_OAUTH_TOKEN — static access token, useful for scripts / CI.
#      Get one with:  gcloud auth print-access-token
#      Note: expires in ~1 hour; rotate it or use a longer-lived option below.
# GOOGLE_OAUTH_TOKEN=ya29.xxx
#
#   3. gcloud auth login — auto-detected from ~/.config/gcloud/ (no env var needed).
#      Run:  gcloud auth login
#      The active account's refresh token is used and auto-refreshes.
#
#   4. GOOGLE_APPLICATION_CREDENTIALS — path to a service-account or
#      authorized-user JSON.  Leave blank if using options 1–3 above.
#      For Vertex AI only: a service account with roles/aiplatform.user can be
#      set here as a fallback when the user's credentials lack Vertex AI access.
#      BigQuery always uses user credentials (options 1–3); this SA is never
#      used for data queries.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
#   5. ADC (gcloud auth application-default login) — last resort.
#      Run:  gcloud auth application-default login
#
# Required IAM roles for the authenticated identity:
#   roles/aiplatform.user      — Vertex AI inference
#   roles/bigquery.dataViewer  — read BigQuery data
#   roles/bigquery.jobUser     — run BigQuery jobs

# ── BigQuery ──────────────────────────────────────────────────────────────────
# Comma-separated list of fully-qualified tables the AI can query.
# Format: project.dataset.table,project2.dataset2.table2
# The FIRST entry is also the primary table used by the scorecard dashboards.
# If left empty, falls back to the individual vars below.
BIGQUERY_TABLES=your_project.your_dataset.your_table

# Legacy single-table vars — used only when BIGQUERY_TABLES is empty.
BIGQUERY_PROJECT_ID=your_data_project_id
BIGQUERY_DATASET=your_dataset
BIGQUERY_TABLE=your_table

# Project where BigQuery query jobs run — billing goes here.
# Resolution order: BQ_JOB_PROJECT_ID → GOOGLE_CLOUD_PROJECT (Cloud Run auto-inject)
#                   → GCP_PROJECT_ID → BIGQUERY_PROJECT_ID
# On Cloud Run this is detected automatically; set it explicitly for local dev.
BQ_JOB_PROJECT_ID=your-gcp-project-id

# ── Live streaming ────────────────────────────────────────────────────────────
# How often (seconds) the backend re-queries BigQuery and pushes fresh data
# to connected clients via SSE. Minimum enforced: 10s. Default: 60s.
LIVE_REFRESH_INTERVAL=60

# ── Production / Cloud Run ────────────────────────────────────────────────────
# Public URL of this service — added to the CORS allowed-origins list.
# Leave blank for local development.
# CLOUD_RUN_URL=https://your-service-abc123-uc.a.run.app

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls Python logger and uvicorn verbosity.
# LOG_LEVEL takes precedence over UVICORN_LOG_LEVEL when both are set.
# Values: debug | info | warning | error
# Use debug locally to see full request/BQ/agent logs; use info or warning in production.
LOG_LEVEL=info
