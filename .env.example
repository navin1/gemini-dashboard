# ── Vertex AI / Gemini ────────────────────────────────────────────────────────
# GCP project where the Vertex AI API is enabled (required).
VERTEX_AI_PROJECT=your-gcp-project-id

# Region where the model runs. us-central1 supports all Gemini models.
VERTEX_AI_LOCATION=us-central1

# Gemini model served through Vertex AI.
# Recommended: gemini-2.5-flash (fast + cheap) or gemini-2.5-pro (more capable).
GEMINI_MODEL=gemini-2.5-flash

# ── Google Authentication ─────────────────────────────────────────────────────
# PRIMARY (recommended for individuals):
#   Run: gcloud auth application-default login
#   No file needed — ADC credentials are picked up automatically.
#   The authenticated user needs:
#     roles/aiplatform.user      — Vertex AI / Agent
#     roles/bigquery.dataViewer  — read BigQuery data
#     roles/bigquery.jobUser     — run BigQuery queries
#     roles/composer.user        — Cloud Composer / Airflow
#
# FALLBACK for Vertex AI only:
#   If the user lacks roles/aiplatform.user, set the path below to a
#   service-account JSON that has that role. The SA is used exclusively
#   for AI inference — BigQuery and Airflow always use the user's own ADC.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── BigQuery ──────────────────────────────────────────────────────────────────
# Comma-separated list of fully-qualified BigQuery tables the AI can query.
# Format: project.dataset.table,project2.dataset2.table2
# - The FIRST entry is the primary table used by all scorecard dashboards.
# - Column schemas are fetched live from BigQuery so the AI always knows what
#   columns are available, even as tables evolve.
# - If left empty, falls back to the individual vars below.
BIGQUERY_TABLES=your_project.your_dataset.your_table

# Legacy single-table vars — used only when BIGQUERY_TABLES is empty
BIGQUERY_PROJECT_ID=your_data_project_id
BIGQUERY_DATASET=your_dataset
BIGQUERY_TABLE=your_table

# Project where BigQuery query jobs run — billing goes here.
# On Cloud Run this is auto-detected; set it explicitly for local dev.
BQ_JOB_PROJECT_ID=your_gcp_project_id

# ── Airflow / Cloud Composer ──────────────────────────────────────────────────
# Comma-separated Name:URL pairs for each Airflow environment.
# Use the Airflow web server URL — the same URL you open in a browser to access
# the Airflow UI (e.g. https://xxxx-dot-us-east4.composer.googleusercontent.com).
# Do NOT use the GCP Composer environment URL from the Cloud Console.
# The FIRST entry is selected by default in the Airflow widget dropdown.
# Format: EnvName:https://your-airflow-webserver-url
AIRFLOW_ENVIRONMENTS=DEV:https://your-dev-composer-url,UAT:https://your-uat-composer-url,PRD:https://your-prod-composer-url

# Comma-separated DAG IDs to monitor (same names assumed across all environments).
AIRFLOW_DAGS=your_dag_1,your_dag_2

# Set to false if SSL verification fails due to a corporate proxy / VPN doing TLS inspection.
# Keep true in production.
AIRFLOW_VERIFY_SSL=true

# ── Live streaming ────────────────────────────────────────────────────────────
# How often (seconds) the backend re-queries BigQuery and pushes fresh data
# to connected clients via SSE. Minimum enforced: 10s. Default: 60s.
LIVE_REFRESH_INTERVAL=60

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls both uvicorn and Python logger verbosity.
# Values: debug | info | warning | error
# Use debug locally to see full request/BQ/Airflow logs; use info or warning in production.
UVICORN_LOG_LEVEL=info
